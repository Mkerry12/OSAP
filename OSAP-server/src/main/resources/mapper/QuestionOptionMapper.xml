<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.mqq.mapper.QuestionOptionMapper">

    <insert id="insertOptionsBatch">
        insert into question_option values
        <foreach collection="questionOptionList" item="questionOption" separator=",">
            (#{questionOption.questionId},#{questionOption.label},#{questionOption.sortOrder},#{questionOption.createAt})
        </foreach>
    </insert>

</mapper>