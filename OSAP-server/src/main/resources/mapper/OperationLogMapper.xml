<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.mqq.mapper.OperationLogMapper">

    <select id="pageQuery" resultType="com.mqq.entity.OperationLog">
        select * from operation_log
        <where>
            <if test="type != null and type != ''">
                and type = #{type}
            </if>
            <if test="startTime != null and startTime != ''">
                and create_at &gt;= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                and create_at &lt;= #{endTime}
            </if>
            <if test="keyword != null and keyword != ''">
                and (operator like concat('%',#{keyword},'%') or action like concat('%',#{keyword},'%'))
            </if>
        </where>
        order by create_at desc
    </select>

</mapper>
